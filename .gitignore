/testing/
/tests/artifacts/
/tests/external/

# Environment
.env

# IDE
.claude/

# Game files (user-specific)
*.iso
ISO DUMPS/

# Vanilla assets (extracted from user's ISO during first-run setup)
utility/assets/vanilla/*
# Keep Sheik folder structure and CSPs (custom assets not in vanilla Melee)
!utility/assets/vanilla/Sheik/
# But ignore Sheik's DAT files (extracted from user's ISO)
utility/assets/vanilla/Sheik/**/*.dat
utility/assets/stages/

# Vanilla DAT files in csp_data (copied from user's ISO during first-run setup)
# Keep animation files (.anim), scene files (.yml), and images - only exclude vanilla Pl*.dat
utility/tools/processor/csp_data/**/Pl*.dat

# Reference files (large vanilla dumps)
reference/vanilla-dump/
reference/costume-examples/
zzzMoreExtras/

# Test sound dumps
**/testsounds/
scripts/build/build/

# Local screenshots
/Screenshot 2026-01-21 150635.png

# libmelee/memory-probe harness venv
tests/nucleus/melee_venv/

# Dev scratch + harness outputs (experiment scripts and test dumps, not app code).
# Root-anchored so they never hide legit nested files of the same type.
/backend/_exp_*.py
/backend/_cap_*.py
/backend/tmp*/
pytest-cache-files-*/
/*.zip
/*.dat
/*.usd
/sheik_*.png
/render_*.png
/sheik_*.jpg
/sheik_*.yml
/csp_test_out/
/door_tex_dump/
/parallel_test/
/*_test_out/

# local release staging (release_to_r2.py)
releases/

# model-lab artifacts (regenerable; NEVER commit ISOs)
/modellab/*.iso
/modellab/*.glb
/modellab/rigkits/
/modellab/out/
/modellab/shots/
/modellab/__pycache__/
