{
  "name": "start-match-as-fox",
  "description": "Boot the Slippi build and start a VS match as Fox vs a random CPU. The keyboard drives the port-3 (green) cursor in this template config. Proven interactively: boot auto-lands in the Online Play submenu; B,B backs out to the Main Menu; Down->A enters VS Mode; A enters Melee -> CSS. On the CSS the cursor starts at panel height, so Right x3 + Left x1 centers it on the port-4 N/A 'door' (A adds a random CPU); Up x2 + Left x5 reaches Fox (middle row, col 2); A locks it (READY TO FIGHT). Start -> Stage Select, Up puts the cursor on Battlefield, A starts the match. Keymap: A=X, B=Z, Start=ENTER, stick=arrows.",
  "steps": [
    { "type": "wait", "ms": 14000 },
    { "type": "checkpoint", "name": "01-boot-online-submenu" },
    { "type": "focus" },

    { "type": "tap", "key": "Z", "durationMs": 90 },
    { "type": "wait", "ms": 700 },
    { "type": "tap", "key": "Z", "durationMs": 90 },
    { "type": "wait", "ms": 700 },
    { "type": "checkpoint", "name": "02-main-menu" },

    { "type": "tap", "key": "DOWN", "durationMs": 90 },
    { "type": "wait", "ms": 500 },
    { "type": "tap", "key": "X", "durationMs": 90 },
    { "type": "wait", "ms": 1600 },
    { "type": "checkpoint", "name": "03-vs-submenu-melee" },
    { "type": "tap", "key": "X", "durationMs": 90 },
    { "type": "wait", "ms": 3000 },
    { "type": "checkpoint", "name": "04-css" },

    { "type": "tap", "key": "RIGHT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "RIGHT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "RIGHT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 250 },
    { "type": "checkpoint", "name": "05-on-port4-na" },
    { "type": "tap", "key": "X", "durationMs": 90 },
    { "type": "wait", "ms": 500 },
    { "type": "checkpoint", "name": "06-cpu-added" },

    { "type": "tap", "key": "UP", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "UP", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "tap", "key": "LEFT", "durationMs": 90 },
    { "type": "wait", "ms": 200 },
    { "type": "checkpoint", "name": "07-on-fox" },
    { "type": "tap", "key": "X", "durationMs": 90 },
    { "type": "wait", "ms": 600 },
    { "type": "checkpoint", "name": "08-fox-locked-ready" },

    { "type": "tap", "key": "ENTER", "durationMs": 90 },
    { "type": "wait", "ms": 2500 },
    { "type": "checkpoint", "name": "09-stage-select" },
    { "type": "tap", "key": "UP", "durationMs": 90 },
    { "type": "wait", "ms": 400 },
    { "type": "checkpoint", "name": "10-on-battlefield" },
    { "type": "tap", "key": "X", "durationMs": 90 },
    { "type": "wait", "ms": 5000 },
    { "type": "checkpoint", "name": "11-match-running" }
  ]
}
